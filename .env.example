# --- Discord ---
DISCORD_TOKEN=your-discord-bot-token

# --- Database ---
# DATABASE_URL host is "127.0.0.1" for host-run dev/tests (not "localhost" — on some machines
# that resolves to the IPv6 loopback first, which hangs since the port is only published on
# IPv4); docker-compose overrides it to "db" for the anecbot container so it can reach the db
# container by service name.
DATABASE_URL=postgresql://anecbot:anecbot@127.0.0.1:5432/anecbot
POSTGRES_USER=anecbot
POSTGRES_PASSWORD=anecbot
POSTGRES_DB=anecbot
MIGRATIONS_DIR=migrations

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=data/anecbot.log

# --- Releases ---
RELEASE_NOTES_PATH=RELEASE_NOTES.md
